# Backend API origin -- defaults to http://localhost:8000 when unset.
VITE_API_BASE=http://localhost:8000

# GitHub App install page: https://github.com/apps/<app-slug>/installations/new
VITE_GITHUB_APP_INSTALL_URL=https://github.com/apps/replace-with-app-slug/installations/new

# Supabase project (GitHub OAuth sign-in). Leaving BOTH unset runs the dashboard
# unauthenticated -- local development only, paired with AUTH_DISABLED=true on the backend.
VITE_SUPABASE_URL=https://replace-with-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-anon-key
