# Database -- asyncpg URL through the Supabase pooler; statement_cache_size is disabled in code for PgBouncer.
DATABASE_URL=postgresql+asyncpg://postgres.example:replace-me@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# GitHub webhook verification -- use the secret configured on the GitHub App.
WEBHOOK_SECRET=replace-with-a-random-webhook-secret

# GitHub App credentials -- prefer a PEM file path; the inline alternative accepts a \n-escaped PEM.
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_PATH=C:\path\to\flagger-app.private-key.pem
GITHUB_APP_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nreplace-with-private-key\n-----END PRIVATE KEY-----

# Deprecated static fallback -- delete once the GitHub App is live for every repository.
GITHUB_TOKEN=github_pat_replace_me

# Browser access -- comma-separated; defaults to http://localhost:5173 when omitted.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Firebase authentication -- use the Firebase project ID, not its display name.
FIREBASE_PROJECT_ID=replace-with-firebase-project-id

# Local development only -- set to true to skip auth; never in a deployed environment.
AUTH_DISABLED=false
